# ===========================================
# 树莓派 NAS 管家 - 环境配置
# ===========================================
# 默认使用 Ollama 本地模型，无需任何 API Key
# 如需切换云端模型（DeepSeek/OpenAI），设置:
#   LLM_PROVIDER=deepseek
#   LLM_BASE_URL=https://api.deepseek.com
#   DEEPSEEK_API_KEY=sk-xxx

# === NAS 连接（必填） ===
NAS_HOST=192.168.1.100
NAS_USERNAME=admin
NAS_PASSWORD=your-nas-password

# === 本地模型（可选，可覆盖 config/agent.yaml） ===
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:7b
# LLM_BASE_URL=http://localhost:11434

# === 下载管理（可选） ===
# QBITTORRENT_URL=http://192.168.1.200:8080
# QBITTORRENT_USERNAME=admin
# QBITTORRENT_PASSWORD=your-qb-password

# === 媒体播放（可选） ===
# JELLYFIN_URL=http://192.168.1.200:8096
# JELLYFIN_API_KEY=your-jellyfin-api-key

# === 飞书 Bot（可选） ===
# FEISHU_ENABLED=true
# FEISHU_APP_ID=cli_xxxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 企业微信 Bot（可选） ===
# WECOM_ENABLED=true
# WECOM_CORP_ID=wwxxxxxxxxxxxx
# WECOM_AGENT_ID=1000001
# WECOM_SECRET=xxx
# WECOM_TOKEN=xxx
